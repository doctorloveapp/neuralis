.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd


# ══════════════════════════════════════════════
# SISTEMA OPERATIVO — LINUX
# ══════════════════════════════════════════════

*~
.nfs*


# ══════════════════════════════════════════════
# LOGS E TEMPORANEI
# ══════════════════════════════════════════════

*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# File temporanei editor
*.swp
*.swo
*.tmp
*.bak
*.orig
*~


